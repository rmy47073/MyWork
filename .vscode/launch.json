{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C++ Launch (GDB)",
      "preLaunchTask": "Build",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/exes/${fileBasenameNoExtension}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "D:\\WorkingSoftware\\MinGW\\bin\\gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "d:/C++/work2",
      "program": "d:/C++/work2/build/Debug/outDebug",
